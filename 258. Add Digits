
//258. Add Digits
class Solution {
    public int addDigits(int num) {
       int tot;
        while(num>9){
            int ans=0;
        while(num!=0){
            tot=num%10;
            ans=tot+ans;
            num=num/10;
        }   
        num=ans;   
        }
        return num; 
    }
}
