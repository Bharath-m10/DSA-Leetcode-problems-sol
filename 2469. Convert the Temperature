//2469. Convert the Temperature
class Solution {
    public double[] convertTemperature(double celsius) {
        double []ans= new double[2];double kelvin;double fahrenheit;
        kelvin = celsius + 273.15;
        fahrenheit = celsius * 1.80 + 32.00;
        ans[0]=kelvin;
        ans[1]=fahrenheit;
        return ans;

        
    }
}
