//1281. Subtract the Product and Sum of Digits of an Integer
class Solution {
    public int subtractProductAndSum(int n) {
        int product=1,sum=0;
        int temp=n;int count=0;int digit;
        while(temp!=0){
            temp=temp/10;
            count++;
        }
        for(int i=0;i<count;i++){
            digit=n%10;
            product=product*digit;
            sum=sum+digit;
            n=n/10;
        }
        return product-sum;
    }
}
